---
import type { Project } from '../data/site';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<article class="card" data-reveal data-reveal-index={index + 5}>
  <div class="card__label">project.sh</div>
  <h3 class="card__title">&gt; {project.title}</h3>
  <p class="card__desc">{project.description}</p>
  {project.tags && project.tags.length > 0 && (
    <div class="card__tags">
      {project.tags.map((tag) => (
        <span class="card__tag">#{tag}</span>
      ))}
    </div>
  )}
  <a class="card__link" href={project.url} target="_blank" rel="noopener noreferrer">
    $ cat learn_more.txt
  </a>
</article>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: border-color var(--duration-fast) ease,
      box-shadow var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent), var(--accent-glow) 0 8px 24px;
    transform: translateY(-2px);
  }

  .card__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-muted);
    margin-bottom: var(--space-2);
  }

  .card__title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
    color: var(--fg-primary);
  }

  .card__desc {
    font-size: var(--text-sm);
    margin: 0 0 var(--space-4);
    color: var(--fg-secondary);
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    background: var(--accent-glow);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .card__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
  }

  .card__link:hover {
    text-decoration: underline;
  }
</style>
