---
import type { Project } from '../data/site';

interface Props {
  projects: Project[];
  githubUser: string;
  revealIndex?: number;
}

const { projects, githubUser, revealIndex = 1 } = Astro.props;
---

<section
  id="projects"
  class="showcase"
  aria-labelledby="projects-heading"
  data-reveal
  data-reveal-index={revealIndex}
  data-github-user={githubUser}
>
  <h2 id="projects-heading" class="section-heading">## # personal_projects</h2>

  <div class="showcase__grid">
    {projects.map((project) => (
      <article
        class="card"
        data-filter-text={`${project.title} ${project.description} ${(project.tags || []).join(' ')}`}
        data-static="true"
      >
        <div class="card__label">project.sh</div>
        <h3 class="card__title">&gt; {project.title}</h3>
        <p class="card__desc">{project.description}</p>
        {project.tags && project.tags.length > 0 && (
          <div class="card__tags">
            {project.tags.slice(0, 3).map((tag) => (
              <span class="card__tag">#{tag}</span>
            ))}
          </div>
        )}
        <a class="card__link" href={project.url} target="_blank" rel="noopener noreferrer">
          $ cat learn_more.txt
        </a>
      </article>
    ))}
  </div>
</section>

<style>
  .showcase {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-20);
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    margin: 0 0 var(--space-6);
  }

  .showcase__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .card {
    padding: var(--space-6);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    transition: border-color var(--duration-fast) ease,
      box-shadow var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent), var(--accent-glow) 0 8px 24px;
    transform: translateY(-2px);
  }

  .card__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-muted);
    margin-bottom: var(--space-2);
  }

  .card__title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
    color: var(--fg-primary);
  }

  .card__desc {
    font-size: var(--text-sm);
    margin: 0 0 var(--space-4);
    color: var(--fg-secondary);
    flex: 1;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    background: var(--accent-glow);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .card__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    margin-top: auto;
  }

  .card__link:hover {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    .card {
      transition: none;
    }
  }
</style>

<script>
  const GITHUB_API = 'https://api.github.com';
  const CACHE_KEY = 'skitz0-gh-repos';
  const CACHE_TTL = 3600000;

  const LANG_COLORS: Record<string, string> = {
    JavaScript: '#f1e05a', TypeScript: '#3178c6', Python: '#3572A5',
    Go: '#00ADD8', Rust: '#dea584', C: '#555555', 'C#': '#178600',
    Shell: '#89e051', Dockerfile: '#384d54', HCL: '#844FBA',
  };

  interface CachedRepo {
    name: string;
    description: string | null;
    url: string;
    stars: number;
    language: string | null;
    pushed_at: string;
    topics: string[];
  }

  const section = document.querySelector<HTMLElement>('.showcase')!;
  const grid = section.querySelector<HTMLElement>('.showcase__grid')!;
  const githubUser = section.dataset.githubUser || '';
  const staticCards = grid.querySelectorAll<HTMLElement>('.card[data-static]');

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function timeAgo(dateString: string): string {
    const seconds = Math.floor((Date.now() - new Date(dateString).getTime()) / 1000);
    const intervals: [number, string][] = [
      [31536000, 'year'], [2592000, 'month'], [86400, 'day'],
      [3600, 'hour'], [60, 'minute'],
    ];
    for (const [secs, label] of intervals) {
      const count = Math.floor(seconds / secs);
      if (count >= 1) return `${count} ${label}${count !== 1 ? 's' : ''} ago`;
    }
    return 'just now';
  }

  function createCard(repo: CachedRepo): HTMLElement {
    const card = document.createElement('article');
    card.className = 'card';
    card.dataset.filterText = [repo.name, repo.description || '', repo.language || '', ...repo.topics].join(' ');

    const label = document.createElement('div');
    label.className = 'card__label';
    label.textContent = 'github.sh';
    card.appendChild(label);

    const title = document.createElement('h3');
    title.className = 'card__title';
    title.textContent = `> ${repo.name}`;
    card.appendChild(title);

    const desc = document.createElement('p');
    desc.className = 'card__desc';
    desc.textContent = repo.description || 'No description';
    card.appendChild(desc);

    const topTopics = repo.topics.slice(0, 3);
    if (topTopics.length > 0) {
      const tagsDiv = document.createElement('div');
      tagsDiv.className = 'card__tags';
      topTopics.forEach((t) => {
        const tag = document.createElement('span');
        tag.className = 'card__tag';
        tag.textContent = `#${t}`;
        tagsDiv.appendChild(tag);
      });
      card.appendChild(tagsDiv);
    }

    const link = document.createElement('a');
    link.className = 'card__link';
    link.href = repo.url;
    link.target = '_blank';
    link.rel = 'noopener noreferrer';
    link.textContent = '$ cat learn_more.txt';
    card.appendChild(link);

    return card;
  }

  async function enrichFromGitHub(): Promise<void> {
    if (!githubUser) return;

    try {
      const cached = localStorage.getItem(CACHE_KEY);
      let repos: CachedRepo[];

      if (cached) {
        const data = JSON.parse(cached);
        if (Date.now() - data.timestamp < CACHE_TTL) {
          repos = data.repos;
        } else {
          repos = await fetchRepos();
        }
      } else {
        repos = await fetchRepos();
      }

      // Match static cards by title and enrich with GitHub metadata
      const repoMap = new Map(repos.map(r => [r.name.toLowerCase(), r]));

      staticCards.forEach(card => {
        const titleEl = card.querySelector('.card__title');
        if (!titleEl) return;
        const name = (titleEl.textContent || '').replace(/^>\s*/, '').trim().toLowerCase();
        const repo = repoMap.get(name);
        if (!repo) return;

        // Add language/stars meta if not already present
        if (!card.querySelector('.card__meta')) {
          const meta = document.createElement('div');
          meta.className = 'card__meta';
          meta.style.cssText = 'display:flex;align-items:center;gap:0.5rem;font-family:var(--font-mono);font-size:var(--text-xs);color:var(--fg-muted);margin-bottom:var(--space-3)';

          if (repo.language) {
            const langSpan = document.createElement('span');
            langSpan.style.cssText = 'display:flex;align-items:center;gap:0.25rem';
            const dot = document.createElement('span');
            dot.style.cssText = `width:10px;height:10px;border-radius:50%;background:${LANG_COLORS[repo.language] || 'var(--fg-muted)'}`;
            langSpan.appendChild(dot);
            langSpan.appendChild(document.createTextNode(repo.language));
            meta.appendChild(langSpan);
          }

          if (repo.stars > 0) {
            const stars = document.createElement('span');
            stars.textContent = `${repo.stars} \u2605`;
            meta.appendChild(stars);
          }

          const time = document.createElement('span');
          time.textContent = timeAgo(repo.pushed_at);
          meta.appendChild(time);

          const desc = card.querySelector('.card__desc');
          if (desc) desc.after(meta);
        }

        repoMap.delete(name);
      });

      // Add remaining GitHub repos not in static list
      repoMap.forEach(repo => {
        grid.appendChild(createCard(repo));
      });

    } catch {
      // Static cards are already showing — no action needed
    }
  }

  async function fetchRepos(): Promise<CachedRepo[]> {
    const res = await fetch(`${GITHUB_API}/users/${githubUser}/repos?sort=updated&per_page=100`);
    if (!res.ok) throw new Error(`GitHub API ${res.status}`);
    const data = await res.json();
    const repos = data
      .filter((r: any) => !r.fork)
      .map((r: any) => ({
        name: r.name, description: r.description, url: r.html_url,
        stars: r.stargazers_count, language: r.language,
        pushed_at: r.pushed_at, topics: r.topics || [],
      }))
      .sort((a: CachedRepo, b: CachedRepo) => {
        if (b.stars !== a.stars) return b.stars - a.stars;
        return new Date(b.pushed_at).getTime() - new Date(a.pushed_at).getTime();
      });

    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ timestamp: Date.now(), repos }));
    } catch {}

    return repos;
  }

  enrichFromGitHub();
</script>
