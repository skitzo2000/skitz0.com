---
import type { Project } from '../data/site';

interface Props {
  projects: Project[];
  githubUser: string;
  revealIndex?: number;
}

const { projects, githubUser, revealIndex = 1 } = Astro.props;
---

<section
  id="projects"
  class="showcase"
  aria-labelledby="projects-heading"
  data-reveal
  data-reveal-index={revealIndex}
  data-github-user={githubUser}
>
  <h2 id="projects-heading" class="section-heading">## # personal_projects</h2>

  <div class="showcase__status" aria-live="polite"></div>

  <div class="showcase__viewport">
    <div class="showcase__track">
      {projects.map((project) => (
        <article
          class="card showcase__card"
          data-filter-text={`${project.title} ${project.description} ${(project.tags || []).join(' ')}`}
          data-static="true"
        >
          <div class="card__label">project.sh</div>
          <h3 class="card__title">&gt; {project.title}</h3>
          <p class="card__desc">{project.description}</p>
          {project.tags && project.tags.length > 0 && (
            <div class="card__tags">
              {project.tags.slice(0, 3).map((tag) => (
                <span class="card__tag">#{tag}</span>
              ))}
            </div>
          )}
          <a class="card__link" href={project.url} target="_blank" rel="noopener noreferrer">
            $ cat learn_more.txt
          </a>
        </article>
      ))}
    </div>
  </div>

  <div class="showcase__nav">
    <button class="showcase__arrow showcase__arrow--prev" aria-label="Previous projects" type="button">
      <span aria-hidden="true">&larr;</span>
    </button>
    <div class="showcase__dots" role="tablist" aria-label="Project pages"></div>
    <button class="showcase__arrow showcase__arrow--next" aria-label="Next projects" type="button">
      <span aria-hidden="true">&rarr;</span>
    </button>
  </div>

  <template class="showcase__skeleton-template">
    <article class="card showcase__card showcase__card--skeleton">
      <div class="card__label skeleton-pulse"></div>
      <h3 class="card__title skeleton-pulse"></h3>
      <p class="card__desc skeleton-pulse"></p>
      <div class="card__tags skeleton-pulse"></div>
      <div class="card__link skeleton-pulse"></div>
    </article>
  </template>

  <div class="showcase__modal" role="dialog" aria-modal="true" aria-label="README viewer" hidden>
    <div class="showcase__modal-backdrop"></div>
    <div class="showcase__modal-content">
      <div class="showcase__modal-header">
        <h3 class="showcase__modal-title"></h3>
        <button class="showcase__modal-close" aria-label="Close README" type="button">&times;</button>
      </div>
      <div class="showcase__modal-body">
        <div class="showcase__modal-loading">Fetching README...</div>
        <div class="showcase__modal-readme"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-20);
    position: relative;
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    margin: 0 0 var(--space-6);
  }

  .showcase__status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    margin-bottom: var(--space-3);
    display: none;
  }

  .showcase__status.visible {
    display: block;
  }

  .showcase__viewport {
    overflow: hidden;
    margin: 0 calc(-1 * var(--space-2));
  }

  .showcase__track {
    display: flex;
    transition: transform 400ms ease-out;
  }

  .showcase__card {
    flex: 0 0 25%;
    min-width: 0;
    padding: var(--space-6);
    margin: 0 var(--space-2);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color var(--duration-fast) ease,
      box-shadow var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
    box-sizing: border-box;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  .showcase__card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent), var(--accent-glow) 0 8px 24px;
    transform: translateY(-2px);
  }

  .card__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-muted);
    margin-bottom: var(--space-2);
  }

  .card__title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
    color: var(--fg-primary);
  }

  .card__desc {
    font-size: var(--text-sm);
    margin: 0 0 var(--space-4);
    color: var(--fg-secondary);
    flex: 1;
  }

  .card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    margin-bottom: var(--space-3);
  }

  .card__meta-lang {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .card__meta-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    background: var(--accent-glow);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .card__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    margin-top: auto;
  }

  .card__link:hover {
    text-decoration: underline;
  }

  /* Skeleton cards */
  .showcase__card--skeleton .skeleton-pulse {
    background: var(--bg-hover);
    border-radius: var(--radius-sm);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .showcase__card--skeleton .card__label.skeleton-pulse {
    width: 60px;
    height: 0.7rem;
    margin-bottom: var(--space-2);
  }

  .showcase__card--skeleton .card__title.skeleton-pulse {
    width: 80%;
    height: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .showcase__card--skeleton .card__desc.skeleton-pulse {
    width: 100%;
    height: 2.5rem;
    margin: 0 0 var(--space-4);
  }

  .showcase__card--skeleton .card__tags.skeleton-pulse {
    width: 60%;
    height: var(--text-xs);
    margin-bottom: var(--space-4);
  }

  .showcase__card--skeleton .card__link.skeleton-pulse {
    width: 50%;
    height: var(--text-sm);
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  /* Navigation */
  .showcase__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }

  .showcase__arrow {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--fg-primary);
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    padding: var(--space-2) var(--space-3);
    cursor: pointer;
    transition: border-color var(--duration-fast) ease,
      background var(--duration-fast) ease;
    line-height: 1;
  }

  .showcase__arrow:hover {
    border-color: var(--accent);
    background: var(--bg-hover);
  }

  .showcase__arrow:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .showcase__dots {
    display: flex;
    gap: var(--space-2);
  }

  .showcase__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background var(--duration-fast) ease;
  }

  .showcase__dot[aria-selected="true"] {
    background: var(--accent);
  }

  .showcase__dot:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  /* Modal */
  .showcase__modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
  }

  .showcase__modal[hidden] {
    display: none;
  }

  .showcase__modal-backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-base);
    opacity: 0.95;
  }

  .showcase__modal-content {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    max-width: 48rem;
    width: 100%;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .showcase__modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--border);
  }

  .showcase__modal-title {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--accent);
    margin: 0;
  }

  .showcase__modal-close {
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--fg-primary);
    font-size: var(--text-xl);
    cursor: pointer;
    padding: var(--space-1) var(--space-3);
    line-height: 1;
    transition: border-color var(--duration-fast) ease;
  }

  .showcase__modal-close:hover {
    border-color: var(--accent);
  }

  .showcase__modal-close:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .showcase__modal-body {
    padding: var(--space-6);
    overflow-y: auto;
    flex: 1;
  }

  .showcase__modal-loading {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    text-align: center;
    padding: var(--space-8);
  }

  .showcase__modal-readme {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--fg-secondary);
  }

  /* README markdown styling */
  .showcase__modal-readme :global(h1),
  .showcase__modal-readme :global(h2),
  .showcase__modal-readme :global(h3),
  .showcase__modal-readme :global(h4) {
    color: var(--fg-primary);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .showcase__modal-readme :global(h1) { font-size: var(--text-2xl); }
  .showcase__modal-readme :global(h2) { font-size: var(--text-xl); }

  .showcase__modal-readme :global(code) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--bg-elevated);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    color: var(--accent);
  }

  .showcase__modal-readme :global(pre) {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin: var(--space-4) 0;
  }

  .showcase__modal-readme :global(pre code) {
    background: none;
    padding: 0;
    color: var(--fg-primary);
  }

  .showcase__modal-readme :global(a) {
    color: var(--accent);
  }

  .showcase__modal-readme :global(img) {
    max-width: 100%;
    border-radius: var(--radius-md);
  }

  .showcase__modal-readme :global(ul),
  .showcase__modal-readme :global(ol) {
    padding-left: var(--space-6);
    margin: var(--space-3) 0;
  }

  .showcase__modal-readme :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: var(--space-4) 0;
    padding: var(--space-2) var(--space-4);
    color: var(--fg-muted);
  }

  .showcase__modal-readme :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-4) 0;
  }

  .showcase__modal-readme :global(th),
  .showcase__modal-readme :global(td) {
    border: 1px solid var(--border);
    padding: var(--space-2) var(--space-3);
    text-align: left;
  }

  .showcase__modal-readme :global(th) {
    background: var(--bg-elevated);
    color: var(--fg-primary);
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .showcase__card {
      flex: 0 0 50%;
    }
  }

  @media (max-width: 767px) {
    .showcase__card {
      flex: 0 0 100%;
    }

    .showcase__modal-content {
      max-height: 90vh;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .showcase__track {
      transition: none;
    }

    .showcase__card {
      transition: none;
    }

    .showcase__card--skeleton .skeleton-pulse {
      animation: none;
      opacity: 0.6;
    }
  }
</style>

<script>
  // === Constants ===
  const GITHUB_API = 'https://api.github.com';
  const CACHE_KEY_REPOS = 'skitz0-gh-repos';
  const CACHE_TTL = 3600000; // 1 hour

  const LANG_COLORS: Record<string, string> = {
    JavaScript: '#f1e05a',
    TypeScript: '#3178c6',
    Python: '#3572A5',
    Go: '#00ADD8',
    Rust: '#dea584',
    C: '#555555',
    'C++': '#f34b7d',
    'C#': '#178600',
    Java: '#b07219',
    Ruby: '#701516',
    PHP: '#4F5D95',
    Shell: '#89e051',
    HTML: '#e34c26',
    CSS: '#563d7c',
    Dockerfile: '#384d54',
    Nix: '#7e7eff',
    Lua: '#000080',
    'Vim Script': '#199f4b',
    Makefile: '#427819',
    HCL: '#844FBA',
  };

  interface CachedRepo {
    name: string;
    description: string | null;
    url: string;
    stars: number;
    language: string | null;
    pushed_at: string;
    topics: string[];
  }

  interface CachedData {
    timestamp: number;
    repos: CachedRepo[];
  }

  // === DOM References ===
  const section = document.querySelector<HTMLElement>('.showcase')!;
  const track = section.querySelector<HTMLElement>('.showcase__track')!;
  const dotsContainer = section.querySelector<HTMLElement>('.showcase__dots')!;
  const prevBtn = section.querySelector<HTMLButtonElement>('.showcase__arrow--prev')!;
  const nextBtn = section.querySelector<HTMLButtonElement>('.showcase__arrow--next')!;
  const statusEl = section.querySelector<HTMLElement>('.showcase__status')!;
  const modal = section.querySelector<HTMLElement>('.showcase__modal')!;
  const modalTitle = modal.querySelector<HTMLElement>('.showcase__modal-title')!;
  const modalLoading = modal.querySelector<HTMLElement>('.showcase__modal-loading')!;
  const modalReadme = modal.querySelector<HTMLElement>('.showcase__modal-readme')!;
  const modalClose = modal.querySelector<HTMLButtonElement>('.showcase__modal-close')!;
  const modalBackdrop = modal.querySelector<HTMLElement>('.showcase__modal-backdrop')!;
  const skeletonTemplate = section.querySelector<HTMLTemplateElement>('.showcase__skeleton-template')!;
  const githubUser = section.dataset.githubUser || '';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // === State ===
  let currentPage = 0;
  let rotationInterval: ReturnType<typeof setInterval> | null = null;
  let totalCards = track.querySelectorAll('.showcase__card').length;

  // Store static HTML before any JS manipulation, for fallback restoration
  const staticHTML = track.innerHTML;

  // === Cache Manager ===
  function getCache(): CachedData | null {
    try {
      const raw = localStorage.getItem(CACHE_KEY_REPOS);
      if (!raw) return null;
      return JSON.parse(raw) as CachedData;
    } catch {
      return null;
    }
  }

  function setCache(repos: CachedRepo[]): void {
    try {
      const data: CachedData = { timestamp: Date.now(), repos };
      localStorage.setItem(CACHE_KEY_REPOS, JSON.stringify(data));
    } catch {
      // localStorage full or unavailable
    }
  }

  function isCacheValid(data: CachedData | null): data is CachedData {
    if (!data) return false;
    return Date.now() - data.timestamp < CACHE_TTL;
  }

  // === GitHub Fetcher ===
  async function fetchRepos(): Promise<CachedRepo[]> {
    const res = await fetch(
      `${GITHUB_API}/users/${githubUser}/repos?sort=updated&per_page=100`
    );
    if (!res.ok) throw new Error(`GitHub API ${res.status}`);
    const data = await res.json();
    return data
      .filter((r: any) => !r.fork)
      .map((r: any) => ({
        name: r.name,
        description: r.description,
        url: r.html_url,
        stars: r.stargazers_count,
        language: r.language,
        pushed_at: r.pushed_at,
        topics: r.topics || [],
      }))
      .sort((a: CachedRepo, b: CachedRepo) => {
        if (b.stars !== a.stars) return b.stars - a.stars;
        return new Date(b.pushed_at).getTime() - new Date(a.pushed_at).getTime();
      });
  }

  async function fetchReadme(repo: string): Promise<string> {
    const cacheKey = `skitz0-gh-readme-${repo}`;
    try {
      const cached = localStorage.getItem(cacheKey);
      if (cached) {
        const parsed = JSON.parse(cached);
        if (Date.now() - parsed.timestamp < CACHE_TTL) return parsed.content;
      }
    } catch { /* ignore */ }

    const res = await fetch(
      `${GITHUB_API}/repos/${githubUser}/${repo}/readme`,
      { headers: { Accept: 'application/vnd.github.v3.raw' } }
    );
    if (!res.ok) throw new Error(`README fetch ${res.status}`);
    const content = await res.text();

    try {
      localStorage.setItem(cacheKey, JSON.stringify({ timestamp: Date.now(), content }));
    } catch { /* ignore */ }

    return content;
  }

  // === Relative Time ===
  function timeAgo(dateString: string): string {
    const now = Date.now();
    const then = new Date(dateString).getTime();
    const seconds = Math.floor((now - then) / 1000);

    const intervals: [number, string][] = [
      [31536000, 'year'],
      [2592000, 'month'],
      [86400, 'day'],
      [3600, 'hour'],
      [60, 'minute'],
    ];

    for (const [secs, label] of intervals) {
      const count = Math.floor(seconds / secs);
      if (count >= 1) {
        return `${count} ${label}${count !== 1 ? 's' : ''} ago`;
      }
    }
    return 'just now';
  }

  // === HTML Escaping ===
  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // === Card Renderer ===
  function showSkeletons(): void {
    while (track.firstChild) track.removeChild(track.firstChild);
    for (let i = 0; i < 8; i++) {
      const clone = skeletonTemplate.content.cloneNode(true) as DocumentFragment;
      track.appendChild(clone);
    }
    totalCards = 8;
    buildDots();
  }

  function renderCards(repos: CachedRepo[]): void {
    while (track.firstChild) track.removeChild(track.firstChild);

    repos.forEach((repo) => {
      const card = document.createElement('article');
      card.className = 'card showcase__card';
      card.dataset.filterText = [repo.name, repo.description || '', repo.language || '', ...repo.topics].join(' ');
      card.dataset.repo = repo.name;

      const label = document.createElement('div');
      label.className = 'card__label';
      label.textContent = 'github.sh';
      card.appendChild(label);

      const title = document.createElement('h3');
      title.className = 'card__title';
      title.textContent = `> ${repo.name}`;
      card.appendChild(title);

      const desc = document.createElement('p');
      desc.className = 'card__desc';
      desc.textContent = repo.description || 'No description';
      card.appendChild(desc);

      // Meta row: language dot + stars + time
      const meta = document.createElement('div');
      meta.className = 'card__meta';

      if (repo.language) {
        const langSpan = document.createElement('span');
        langSpan.className = 'card__meta-lang';
        const dot = document.createElement('span');
        dot.className = 'card__meta-dot';
        dot.style.background = LANG_COLORS[repo.language] || 'var(--fg-muted)';
        langSpan.appendChild(dot);
        langSpan.appendChild(document.createTextNode(repo.language));
        meta.appendChild(langSpan);
      }

      const starsSpan = document.createElement('span');
      starsSpan.textContent = `${repo.stars} \u2605`;
      meta.appendChild(starsSpan);

      const timeSpan = document.createElement('span');
      timeSpan.textContent = timeAgo(repo.pushed_at);
      meta.appendChild(timeSpan);

      card.appendChild(meta);

      // Topics
      const topTopics = repo.topics.slice(0, 3);
      if (topTopics.length > 0) {
        const tagsDiv = document.createElement('div');
        tagsDiv.className = 'card__tags';
        topTopics.forEach((t) => {
          const tag = document.createElement('span');
          tag.className = 'card__tag';
          tag.textContent = `#${t}`;
          tagsDiv.appendChild(tag);
        });
        card.appendChild(tagsDiv);
      }

      const link = document.createElement('a');
      link.className = 'card__link';
      link.href = repo.url;
      link.target = '_blank';
      link.rel = 'noopener noreferrer';
      link.textContent = '$ cat learn_more.txt';
      card.appendChild(link);

      card.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.card__link')) return;
        openModal(repo.name);
      });

      track.appendChild(card);
    });

    totalCards = repos.length;
    currentPage = 0;
    buildDots();
    slideTo(0);
  }

  // === Carousel Engine ===
  function getCardsPerPage(): number {
    const width = window.innerWidth;
    if (width < 768) return 1;
    if (width < 1024) return 2;
    return 4;
  }

  function getPageCount(): number {
    const perPage = getCardsPerPage();
    return Math.max(1, Math.ceil(totalCards / perPage));
  }

  function slideTo(page: number): void {
    const pageCount = getPageCount();
    currentPage = ((page % pageCount) + pageCount) % pageCount;
    const perPage = getCardsPerPage();
    const offset = currentPage * perPage * (100 / totalCards);
    track.style.transform = `translateX(-${offset}%)`;
    updateDots();
  }

  function next(): void {
    slideTo(currentPage + 1);
  }

  function prev(): void {
    slideTo(currentPage - 1);
  }

  function buildDots(): void {
    while (dotsContainer.firstChild) dotsContainer.removeChild(dotsContainer.firstChild);
    const pageCount = getPageCount();
    for (let i = 0; i < pageCount; i++) {
      const dot = document.createElement('button');
      dot.className = 'showcase__dot';
      dot.setAttribute('role', 'tab');
      dot.setAttribute('aria-selected', i === currentPage ? 'true' : 'false');
      dot.setAttribute('aria-label', `Page ${i + 1}`);
      dot.addEventListener('click', () => slideTo(i));
      dotsContainer.appendChild(dot);
    }
  }

  function updateDots(): void {
    const dots = dotsContainer.querySelectorAll<HTMLButtonElement>('.showcase__dot');
    dots.forEach((dot, i) => {
      dot.setAttribute('aria-selected', i === currentPage ? 'true' : 'false');
    });
  }

  function startRotation(): void {
    if (prefersReducedMotion) return;
    stopRotation();
    rotationInterval = setInterval(next, 8000);
  }

  function stopRotation(): void {
    if (rotationInterval) {
      clearInterval(rotationInterval);
      rotationInterval = null;
    }
  }

  // === README Modal ===
  let markedParse: ((md: string) => string) | null = null;

  async function openModal(repo: string): Promise<void> {
    modalTitle.textContent = `> ${repo}/README.md`;
    modalLoading.style.display = 'block';
    modalReadme.textContent = '';
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    stopRotation();

    try {
      const [mdContent] = await Promise.all([
        fetchReadme(repo),
        loadMarked(),
      ]);

      if (markedParse) {
        // marked output is trusted markdown-to-HTML conversion of README content
        // sourced from the GitHub API (same trust level as viewing on github.com)
        const rendered = markedParse(mdContent);
        modalReadme.innerHTML = rendered;
      } else {
        modalReadme.textContent = mdContent;
      }
    } catch {
      const fallbackP = document.createElement('p');
      fallbackP.style.color = 'var(--fg-muted)';
      fallbackP.textContent = 'README unavailable. ';
      const fallbackLink = document.createElement('a');
      fallbackLink.href = `https://github.com/${githubUser}/${repo}`;
      fallbackLink.target = '_blank';
      fallbackLink.rel = 'noopener noreferrer';
      fallbackLink.textContent = 'View on GitHub';
      fallbackP.appendChild(fallbackLink);
      modalReadme.textContent = '';
      modalReadme.appendChild(fallbackP);
    }

    modalLoading.style.display = 'none';
    modalClose.focus();
  }

  async function loadMarked(): Promise<void> {
    if (markedParse) return;
    try {
      const { marked } = await import('marked');
      markedParse = (md: string) => marked(md) as string;
    } catch {
      markedParse = null;
    }
  }

  function closeModal(): void {
    modal.hidden = true;
    document.body.style.overflow = '';
    startRotation();
  }

  modalClose.addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) {
      closeModal();
    }
  });

  // === Status Indicator ===
  function setStatus(text: string): void {
    statusEl.textContent = text;
    statusEl.classList.add('visible');
  }

  // === Event Listeners ===
  prevBtn.addEventListener('click', () => {
    prev();
    stopRotation();
    startRotation();
  });

  nextBtn.addEventListener('click', () => {
    next();
    stopRotation();
    startRotation();
  });

  // Pause on hover
  const viewport = section.querySelector<HTMLElement>('.showcase__viewport')!;
  viewport.addEventListener('mouseenter', stopRotation);
  viewport.addEventListener('mouseleave', startRotation);

  // Responsive recalculation
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      buildDots();
      slideTo(Math.min(currentPage, getPageCount() - 1));
    }, 150);
  });

  // === Init ===
  async function initShowcase(): Promise<void> {
    if (!githubUser) {
      buildDots();
      startRotation();
      return;
    }

    const cached = getCache();
    if (isCacheValid(cached)) {
      renderCards(cached.repos);
      setStatus('Cached');
      startRotation();
      return;
    }

    showSkeletons();

    try {
      const repos = await fetchRepos();
      setCache(repos);
      renderCards(repos);
      setStatus('Live from GitHub');
    } catch {
      // Restore static fallback cards rendered by Astro at build time
      const template = document.createElement('template');
      template.innerHTML = staticHTML;
      while (track.firstChild) track.removeChild(track.firstChild);
      track.appendChild(template.content);
      totalCards = track.querySelectorAll('.showcase__card').length;
      statusEl.textContent = '';
      statusEl.classList.remove('visible');
    }

    buildDots();
    startRotation();
  }

  buildDots();
  initShowcase();
</script>
