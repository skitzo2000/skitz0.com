---
import type { SkillCategory } from '../data/site';

interface Props {
  skills: SkillCategory[];
  revealIndex?: number;
}

const { skills, revealIndex = 2 } = Astro.props;
---

<section id="skills" class="skills" aria-labelledby="skills-heading" data-reveal data-reveal-index={revealIndex}>
  <h2 id="skills-heading" class="section-heading">## > technical_proficiencies</h2>
  <div class="skills__grid">
    {skills.map((group, i) => (
      <div class="skills__category">
        <h3 class="skills__category-name">$ {group.category.toLowerCase().replace(/\s+/g, '_')}</h3>
        <ul class="skills__list">
          {group.items.map((item) => (
            <li class="skills__item">
              <span class="skills__tag">#{item}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .skills {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    margin: 0 0 var(--space-6);
  }

  .skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .skills__category {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }

  .skills__category-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg-secondary);
    margin: 0 0 var(--space-4);
  }

  .skills__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .skills__item {
    margin: 0;
  }

  .skills__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    background: var(--accent-glow);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }
</style>
