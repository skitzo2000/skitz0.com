---
interface Props {
  content: string;
  revealIndex?: number;
}

const { content, revealIndex = 0 } = Astro.props;
---

<section id="about" class="about" aria-labelledby="about-heading" data-reveal data-reveal-index={revealIndex}>
  <h2 id="about-heading" class="section-heading">## # about_me</h2>
  <div class="about__body">
    <p class="about__text">{content}</p>
  </div>
</section>

<style>
  .about {
    max-width: var(--container-narrow);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    margin: 0 0 var(--space-6);
  }

  .about__body {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .about__text {
    margin: 0;
    color: var(--fg-secondary);
  }
</style>
